# Database
DATABASE_URL=postgresql://user:password@localhost:5432/causa

# API authentication (external callers need Bearer token)
API_SECRET=your-api-secret-here

# Cron secret for scheduled jobs (x-cron-secret header)
CRON_SECRET=your-cron-secret-here

# LLM API key encryption (64 hex chars, generate with: openssl rand -hex 32)
LLM_ENCRYPTION_KEY=

# Python backtest microservice
BACKTEST_SERVICE_URL=http://localhost:8100

# Set to "true" to use mock data instead of database
NEXT_PUBLIC_USE_MOCK_DATA=false

# Frontend API base URL (leave empty for same-origin)
NEXT_PUBLIC_API_URL=
