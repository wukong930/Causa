# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://causa:causa_dev@localhost:5433/causa

# ─── API Authentication ──────────────────────────────────────────────────────
# External API callers need: Authorization: Bearer <API_SECRET>
# Leave empty in development to skip auth
API_SECRET=
# Cron jobs validated via x-cron-secret header
CRON_SECRET=

# ─── LLM ─────────────────────────────────────────────────────────────────────
# At least one LLM provider key is required for reasoning features
# Keys are encrypted at rest using LLM_ENCRYPTION_KEY
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# Optional: override default model (e.g. gpt-4o, claude-sonnet-4-20250514, deepseek-chat)
LLM_MODEL=
# 64 hex chars for API key encryption (generate: openssl rand -hex 32)
LLM_ENCRYPTION_KEY=

# ─── Weaviate (Vector Store) ─────────────────────────────────────────────────
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=
WEAVIATE_GRPC_HOST=localhost
WEAVIATE_GRPC_PORT=50051

# ─── External Services ──────────────────────────────────────────────────────
# Python backtest microservice
BACKTEST_SERVICE_URL=http://localhost:8100
# FRED API for macro indicators (free key: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# ─── Frontend ────────────────────────────────────────────────────────────────
# Set to "true" to use mock data (development only)
NEXT_PUBLIC_USE_MOCK_DATA=false
# API base URL (leave empty for same-origin)
NEXT_PUBLIC_API_URL=

# ─── Docker Compose overrides ────────────────────────────────────────────────
POSTGRES_USER=causa
POSTGRES_PASSWORD=causa_dev
